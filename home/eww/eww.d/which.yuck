(defwidget which-box [title contents]
           (box
            :class "which"
            :orientation "vertical"
            :space-evenly false
            (label :class "which-title"
                   :halign "start"
                   :text title)
            (box :orientation "horizontal"
                 (for col in contents
                      (box :class "which-col"
                           :orientation "vertical"
                           (for el in col
                                (box :class "which-entry"
                                     :orientation "horizontal"
                                     :space-evenly false
                                     (label :class "which-key"
                                            :width 40
                                            :xalign 1.0
                                            :text {el.key})
                                     (label :class "which-column"
                                            :text ":")
                                     (label :class "which-description"
                                            :text {el.description}))))))))

(defwindow which-popup [title contents]
           :geometry (geometry :anchor "bottom right"
                               :x "20px"
                               :y "20px")
           :stacking "overlay"
           (which-box
            :title title
            :contents contents))
